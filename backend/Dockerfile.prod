FROM amazoncorretto:26-al2023@sha256:3b702fe5f77fc9f6281f167deebd4f06d44dd560a7d3ccf9e7392f221454ad6b AS builder

RUN yum install -y findutils && yum clean all

WORKDIR /workspace

COPY gradlew gradlew
COPY gradle gradle
COPY build.gradle.kts settings.gradle.kts gradle.properties ./

RUN chmod +x ./gradlew

COPY src src

RUN ./gradlew --no-daemon bootJar

FROM ubuntu:24.04@sha256:4fbb8e6a8395de5a7550b33509421a2bafbc0aab6c06ba2cef9ebffbc7092d90

COPY --from=builder /usr/lib/jvm/java-26-amazon-corretto /usr/lib/jvm/java-26-amazon-corretto

ENV JAVA_HOME=/usr/lib/jvm/java-26-amazon-corretto
ENV PATH="${JAVA_HOME}/bin:${PATH}"
ENV JAVA_TOOL_OPTIONS="-Djava.awt.headless=true"
ENV TESSDATA_PREFIX=/usr/share/tesseract-ocr/5/tessdata

RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
      ca-certificates \
      ffmpeg \
      fontconfig \
      ghostscript \
      imagemagick \
      libraw-bin \
      potrace \
      qpdf \
      librsvg2-bin \
      tesseract-ocr \
      tesseract-ocr-rus; \
    mkdir -p /app /data/processing /tmp/jack-processing; \
    rm -rf /var/lib/apt/lists/*; \
    groupadd --gid 10001 jack; \
    useradd --uid 10001 --gid jack --no-create-home --shell /usr/sbin/nologin jack; \
    chown -R jack:jack /app /data/processing /tmp/jack-processing; \
    java -version

WORKDIR /app

COPY --from=builder /workspace/build/libs/*.jar /app/jack.jar

USER 10001:10001

EXPOSE 8080

CMD ["java", "-jar", "/app/jack.jar"]
